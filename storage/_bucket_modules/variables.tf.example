# Bucket Variables Template
# Copy this file to your bucket folder and rename to variables.tf

variable "bucket" {
  description = "Configuration for GCS bucket"
  type = object({
    name          = string
    location      = string
    storage_class = string
    labels        = map(string)
    iam_members = list(object({
      role   = string
      member = string
    }))
    lifecycle_rules = optional(list(object({
      action_type   = string
      age           = optional(number)
      created_before = optional(string)
    })))
  })

  default = {
    name          = "your-bucket-name"
    location      = "asia-southeast1"
    storage_class = "STANDARD"
    labels = {
      environment = "prod"
      team       = "data"
    }
    iam_members   = []
  }
}
