{
  "table_name": "events",
  "dataset": "analytics",
  "partitioning": {
    "type": "DAY",
    "field": "event_time"
  },
  "clustering": ["event_type", "source"],
  "schema": [
    {
      "name": "event_id",
      "type": "STRING",
      "mode": "REQUIRED",
      "description": "Unique event identifier (UUID)"
    },
    {
      "name": "event_type",
      "type": "STRING",
      "mode": "REQUIRED",
      "description": "Type of event (click, view, purchase, etc.)"
    },
    {
      "name": "event_time",
      "type": "TIMESTAMP",
      "mode": "REQUIRED",
      "description": "Event timestamp"
    },
    {
      "name": "user_id",
      "type": "STRING",
      "mode": "NULLABLE",
      "description": "User who triggered the event"
    },
    {
      "name": "session_id",
      "type": "STRING",
      "mode": "NULLABLE",
      "description": "User session identifier"
    },
    {
      "name": "source",
      "type": "STRING",
      "mode": "NULLABLE",
      "description": "Event source (web, mobile, api)"
    },
    {
      "name": "page_url",
      "type": "STRING",
      "mode": "NULLABLE",
      "description": "Page URL where event occurred"
    },
    {
      "name": "properties",
      "type": "JSON",
      "mode": "NULLABLE",
      "description": "Event properties as JSON"
    },
    {
      "name": "created_at",
      "type": "TIMESTAMP",
      "mode": "REQUIRED",
      "description": "Record creation timestamp"
    }
  ]
}
